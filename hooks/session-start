#!/usr/bin/env bash
# SessionStart hook for Recall plugin
# Injects the recall skill content so Claude knows to use recall tools for all memory operations.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read the recall skill content
recall_skill_content=$(cat "${PLUGIN_ROOT}/skills/recall/SKILL.md" 2>&1 || echo "Error reading recall skill")

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

recall_escaped=$(escape_for_json "$recall_skill_content")
session_context="<RECALL_PLUGIN>\nYou have the Recall memory system installed.\n\n**Below is the full content of your 'recall' skill. You MUST follow these rules for ALL memory operations — loading, saving, searching, checking. Invoke this skill before any recall_* tool use.**\n\n${recall_escaped}\n\n**IMPORTANT:** When the user asks about any topic that could have a memory, use recall_search/recall_load — do NOT use manual file Read or Explore agents to find memory content.\n</RECALL_PLUGIN>"

# Output context injection for Claude Code
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
